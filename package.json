{
    "name": "starship-alexandria",
    "version": "0.1.0",
    "description": "A cozy roguelike web game about recovering lost literature from post-apocalyptic Earth. Built with Phaser 3, Next.js, and TypeScript.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sethwilsonUS/starship-alexandria.git"
    },
    "author": "Seth Wilson",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/sethwilsonUS/starship-alexandria/issues"
    },
    "homepage": "https://github.com/sethwilsonUS/starship-alexandria#readme",
    "keywords": [
        "phaser",
        "phaser3",
        "roguelike",
        "next",
        "nextjs",
        "typescript",
        "game"
    ],
    "scripts": {
        "dev": "next dev -p 8080",
        "clean": "rm -rf dist .next",
        "build": "npm run validate-content && next build",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/",
        "typecheck": "tsc --noEmit",
        "validate-content": "node scripts/validate-content.js"
    },
    "dependencies": {
        "next": "^16.1.6",
        "phaser": "^3.90.0",
        "react": "19.0.0",
        "react-dom": "19.0.0",
        "rot-js": "^2.2.1",
        "uuid": "^13.0.0",
        "yaml": "^2.8.2",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/uuid": "^10.0.0",
        "eslint": "^9.39.3",
        "eslint-config-next": "^16.1.6",
        "ts-node": "^10.9.2",
        "typescript": "^5",
        "vitest": "^4.0.18"
    }
}
